# ─────────────────────────────────────────────────────────────────────────────
# MyAccounts — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Full PostgreSQL connection string
DATABASE_URL=postgres://myaccounts:changeme@localhost:5432/myaccounts

# Set to "true" if your DB requires SSL (e.g. Neon, Supabase)
DATABASE_SSL=false

# For docker-compose only — used to configure the postgres service
POSTGRES_DB=myaccounts
POSTGRES_USER=myaccounts
POSTGRES_PASSWORD=changeme

# ── Auth ──────────────────────────────────────────────────────────────────────
# Random secret used to sign JWT tokens — use a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret-value

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# Allowed frontend origin for CORS
FRONTEND_URL=http://localhost:3000

# ── Frontend ──────────────────────────────────────────────────────────────────
# Base URL of the backend API — used by the Vite frontend
VITE_API_URL=http://localhost:5000/api

# ── Optional services ─────────────────────────────────────────────────────────
# OpenAI API key — required for AI Insights feature
OPENAI_API_KEY=sk-...

# SMSLenz credentials — required for SMS messaging feature
SMS_USER_ID=
SMS_API_KEY=
SMS_BASE_URL=https://www.smslenz.lk/api
SMS_SENDER_ID=SMSlenzDEMO

# ── Ports (docker-compose) ────────────────────────────────────────────────────
BACKEND_PORT=5000
FRONTEND_PORT=3000
