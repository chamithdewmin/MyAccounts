PORT=5000
DATABASE_URL=postgresql://myuser:password@localhost:5432/myaccounts
# Set DATABASE_SSL=true only for external DBs that require SSL (e.g. Supabase, Railway). Leave unset for internal DBs.
# DATABASE_SSL=true
JWT_SECRET=your-super-secret-jwt-key-change-in-production
NODE_ENV=development
FRONTEND_URL=https://myaccounts.logozodev.com

# File Manager — uploads MUST survive redeploys (DB rows alone are not enough).
# Without UPLOADS_DIR on Docker/K8s, files live inside the image layer and disappear on each deploy →
# "Preview failed / File missing on disk" for old rows. Set this to a path backed by a volume or bind-mount.
#
# Docker example (compose): UPLOADS_DIR=/data/uploads  +  volumes: myaccounts_uploads:/data/uploads
# Linux VM: UPLOADS_DIR=/var/lib/myaccounts/uploads
# UPLOADS_DIR=
#
# Production safety (default true): when true and NODE_ENV=production, backend refuses startup
# unless UPLOADS_DIR is set, preventing silent data loss on redeploy.
# REQUIRE_PERSISTENT_UPLOADS=true

# Optional: AI Insights (suggestions & ask) — OpenAI Chat Completions
# Create a key at https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
# AI_MODEL=gpt-4o-mini
